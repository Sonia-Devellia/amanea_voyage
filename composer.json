{
    "name": "amaneav/voyage",
    "description": "Amanéa Voyage — Création de voyage sur-mesure",
    "type": "project",

    "authors": [
        {
            "name": "Sonia Devellia",
            "email": "sonia@example.com",
            "role": "Developer"
        }
    ],

    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6"
    },

    "autoload": {
        "psr-4": {
            "Config\\":                   "config/",
            "App\\Models\\":              "app/models/",
            "App\\Services\\":             "app/services/",
            "App\\Controllers\\":         "app/controllers/",
            "App\\Controllers\\Admin\\":  "app/controllers/admin/",
            "App\\Controllers\\Client\\": "app/controllers/client/"
        }
    },

    "scripts": {
        "refresh": "composer dump-autoload"
    },

    "config": {
        "optimize-autoloader": true
    }
}